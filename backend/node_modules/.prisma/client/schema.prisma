datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  EXTREME
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
}

enum Category {
  FOOD
  ELECTRONICS
  FASHION
  ACCESSORIES
  GIFTCARDS
  LEAVES
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(EMPLOYEE)
  avatar       String?
  xp           Int      @default(0)
  level        Int      @default(1)
  streak       Int      @default(0)
  department   String
  createdAt    DateTime @default(now())

  assignedTasks Task[]       @relation("AssignedTo")
  managedTasks  Task[]       @relation("AssignedBy")
  redemptions   Redemption[]
  badges        UserBadge[]
}

model Task {
  id             String     @id @default(uuid())
  title          String
  description    String
  difficulty     Difficulty @default(MEDIUM)
  xp             Int
  dueDate        DateTime
  status         TaskStatus @default(TODO)
  assignedToId   String
  assignedTo     User       @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedById   String
  assignedBy     User       @relation("AssignedBy", fields: [assignedById], references: [id])
  completionTime String?
  qualityScore   Int?
  feedback       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Reward {
  id          String       @id @default(uuid())
  title       String
  description String
  category    Category
  cost        Int
  stock       Int
  image       String
  iconName    String
  redemptions Redemption[]
}

model Redemption {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rewardId  String
  reward    Reward   @relation(fields: [rewardId], references: [id])
  claimedAt DateTime @default(now())
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String
  iconName    String
  rarity      String
  users       UserBadge[]
}

model UserBadge {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  badgeId    String
  badge      Badge    @relation(fields: [badgeId], references: [id])
  unlockedAt DateTime @default(now())

  @@unique([userId, badgeId])
}
